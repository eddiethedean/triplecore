{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://triplecore.dev/schemas/query.schema.json",
  "title": "SemanticQuery",
  "type": "object",
  "required": ["entity"],
  "properties": {
    "entity": { "type": "string" },
    "fields": { "type": "array", "items": { "type": "string" } },
    "filters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "operator", "value"],
        "properties": {
          "field": { "type": "string" },
          "operator": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "limit": { "type": "integer", "minimum": 1 }
  }
}
